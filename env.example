# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Specific Gemini keys for higher rate limits per feature
RADAR_GEMINI_API_KEY=
CAREER_MENTOR_GEMINI_API_KEY=
RESUME_PARSER_GEMINI_API_KEY=
USE_CASES_GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AUTH_TOKEN/API_KEY: Required for all external service calls (Radar, Resume Tools, etc.)
AUTH_TOKEN=
API_KEY=
CHATBOT_API_KEY=

# api keys
CHATBOT_GEMINI_API_KEY=your_chatbot_gemini_api_key_here
CHATBOT_API_KEY=your_chatbot_webhook_key_here
OPENAI_API_KEY=your_openai_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key
SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# JSearch / RapidAPI keys
RAPIDAPI_KEY=your_first_jsearch_key_from_account_1
RAPIDAPI_KEY_2=your_second_jsearch_key_from_account_2
# SerpAPI keys
SERP_API_KEY=your_first_serpapi_key_from_account_1
SERP_API_KEY_2=your_second_serpapi_key_from_account_2

# ALLOWED_ORIGINS: Comma-separated list of exact origins allowed for CORS.
# Required in production. If not set, all cross-origin requests are rejected.
# Example: https://skillsync-ai.web.app,https://your-app-xyz123.run.app
ALLOWED_ORIGINS=

# Cache TTLs (optional — defaults shown)
PHASE_EXPLAIN_TTL_DAYS=30
SKILL_GAP_TTL_DAYS=30
TREND_TTL_DAYS=14
RADAR_TTL_HOURS=24
MENTOR_TTL_HOURS=24
USECASES_TTL_HOURS=12

# Assessment limits
MAX_FREE_ASSESSMENTS=3